#!/usr/bin/env bash
set -euo pipefail

if ! command -v podman >/dev/null 2>&1; then
    echo "podman is not installed; run the host playbook so the ansible_pull dependency installs it" >&2
    exit 1
fi

usage() {
    cat <<'EOF'
usage: neovim-container [--fresh] [--rebuild-image] [--help] [-- NVIM_ARGS...]

Run this repository's Neovim config in an isolated Fedora container.

Options:
    --fresh          Use disposable Neovim data for this run. This tests
                    first-run lazy.nvim and plugin installation.
    --rebuild-image  Rebuild the Fedora image even if the matching tag exists.
    --help           Show this help text.
EOF
}

fresh=false
rebuild_image=false

while [ "$#" -gt 0 ]; do
    case "$1" in
        --fresh)
            fresh=true
            shift
            ;;
        --rebuild-image)
            rebuild_image=true
            shift
            ;;
        --help)
            usage
            exit 0
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

repo_root="$(git rev-parse --show-toplevel)"
skill_dir="$repo_root/.agents/skills/test-neovim-config"
fedora_version="$(
    . /etc/os-release
    printf '%s' "${VERSION_ID:?}"
)"
image_name="homelab-neovim-test:fedora-${fedora_version}"

if "$rebuild_image" || ! podman image exists "$image_name"; then
    echo "building $image_name" >&2
    podman build \
        --quiet \
        --tag "$image_name" \
        --build-arg "FEDORA_VERSION=$fedora_version" \
        --file "$skill_dir/Containerfile" \
        "$skill_dir"
fi

podman_mounts=(
    --tmpfs /root/.config/nvim
    --tmpfs /root/.cache/nvim
    --tmpfs /root/.local/state/nvim
    --mount type=bind,source="$skill_dir",destination=/workspace/test-neovim-config,readonly
    --mount type=bind,source="$repo_root/dotfiles/nvim",destination=/workspace/nvim-config,readonly
)

if ! "$fresh"; then
    podman_mounts+=(
        --mount type=volume,source=homelab-neovim-data,destination=/root/.local/share/nvim
    )
fi

podman run \
    --rm \
    --cap-drop=all \
    --pull=never \
    --security-opt label=disable \
    --security-opt no-new-privileges \
    --workdir /workspace/test-neovim-config \
    "${podman_mounts[@]}" \
    "$image_name" \
    sh -c 'cp -R /workspace/nvim-config/. /root/.config/nvim/ && exec nvim --headless "$@" "+lua if vim.v.errmsg ~= \"\" then io.stderr:write(vim.v.errmsg .. \"\\n\"); vim.cmd(\"cquit 1\") end" +qa!' \
    sh "$@"
