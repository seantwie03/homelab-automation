prefix_rule(pattern=["ansible-lint"], decision="allow")
prefix_rule(pattern=["ansible-playbook", "--syntax-check"], decision="allow")
prefix_rule(pattern=["ansible-doc"], decision="allow")
prefix_rule(pattern=[".agents/skills/check-homelab-host/scripts/list-roles.sh"], decision="allow")
prefix_rule(pattern=[".agents/skills/query-running-emacs/scripts/query-emacs-eval.sh"], decision="allow")
prefix_rule(pattern=[".agents/skills/test-emacs-config/scripts/emacs-container"], decision="allow")
prefix_rule(pattern=[".agents/skills/test-neovim-config/scripts/neovim-container"], decision="allow")
prefix_rule(pattern=["emacs", "--batch", "--quick", "--eval", "(setq my--initial-gc-threshold 800000)", "--load", "dotfiles/emacs/init.el", "--eval", "(princ \"ok\\n\")"], decision="allow")
