    (cl-letf (((symbol-function 'my--org-visible-fold-level)
               (lambda () 3))
              ((symbol-function 'outline-hide-sublevels)
               (lambda (level)
                 (setq hidden-to level))))
      (my/org-hide-next-fold-level))
    (should (= hidden-to 2))))

(ert-deftest my/org-hide-next-fold-level-stops-at-level-one ()
  (let (hidden-to)
    (cl-letf (((symbol-function 'my--org-visible-fold-level)
               (lambda () 1))
              ((symbol-function 'outline-hide-sublevels)
               (lambda (level)
                 (setq hidden-to level))))
      (my/org-hide-next-fold-level))
    (should (= hidden-to 1))))

(ert-deftest my/org-show-next-fold-level-increases-the-visible-level ()
  (let (hidden-to)
    (cl-letf (((symbol-function 'my--org-visible-fold-level)
               (lambda () 3))
              ((symbol-function 'outline-hide-sublevels)
               (lambda (level)
                 (setq hidden-to level))))
      (my/org-show-next-fold-level))
    (should (= hidden-to 4))))

(ert-deftest my/org-task-capture-targets-the-inbox-file ()
  (require 'org-capture)
  (let* ((template (assoc "t" org-capture-templates))
         (target (nth 3 template)))
    (should (equal target
                   `(file ,(expand-file-name "inbox.org" org-directory))))))

(ert-deftest my/org-task-capture-separates-top-level-headings ()
  (require 'org-capture)
  (let* ((file (make-temp-file "org-capture-spacing-" nil ".org"
                               "* TODO Existing\n"))
         (template (copy-tree (assoc "t" org-capture-templates)))
         (org-capture-templates (list template)))
    (unwind-protect
        (progn
          (setf (nth 3 template) `(file ,file))
          (org-capture-string "" "t")
          (when (org-capture-get :buffer)
            (org-capture-finalize))
          (with-temp-buffer
            (insert-file-contents file)
            (should (string-match-p
                     "\\* TODO Existing\n\n\\* TODO"
                     (buffer-string)))))
      (ignore-errors (org-capture-kill))
      (delete-file file))))

(ert-deftest my/org-capture-starts-in-evil-insert-state ()
  (require 'org-capture)
  (should (memq #'evil-insert-state org-capture-mode-hook))
  (let ((org-capture-mode-hook '(evil-insert-state))
        called)
    (cl-letf (((symbol-function 'evil-insert-state)
               (lambda (&optional _count)
                 (setq called t))))
      (run-hooks 'org-capture-mode-hook))
    (should called)))

(ert-deftest my/org-rich-text-export-uses-the-active-region ()
  (let (clipboard kill-ring-text)
    (cl-letf (((symbol-function 'kill-new)
               (lambda (text &optional _replace)
                 (setq kill-ring-text text)))
              ((symbol-function 'gui-set-selection)
               (lambda (_type data)
                 (setq clipboard data))))
      (with-temp-buffer
        (org-mode)
        (insert "* First\nSelected *bold* text.\n\n* Second\nExcluded text.\n")
        (goto-char (point-min))
        (set-mark (save-excursion
                    (search-forward "* Second")
                    (line-beginning-position)))
        (activate-mark)
        (my/org-export-to-clipboard-as-rich-text)))
    (let ((html (get-text-property 0 'text/html clipboard)))
      (should (string-match-p "Selected" kill-ring-text))
      (should-not (string-match-p "Excluded" kill-ring-text))
      (should (string-match-p "Selected" html))
      (should (string-match-p "<b>bold</b>" html))
      (should-not (string-match-p "Excluded" html)))))

(ert-deftest my/org-rich-text-export-uses-the-whole-buffer-without-a-region ()
  (let (clipboard kill-ring-text)
    (cl-letf (((symbol-function 'kill-new)
               (lambda (text &optional _replace)
                 (setq kill-ring-text text)))
              ((symbol-function 'gui-set-selection)
               (lambda (_type data)
                 (setq clipboard data))))
      (with-temp-buffer
        (org-mode)
        (insert "* First\nFirst text.\n\n* Second\nSecond text.\n")
        (my/org-export-to-clipboard-as-rich-text)))
    (let ((html (get-text-property 0 'text/html clipboard)))
      (should (string-match-p "First text" kill-ring-text))
      (should (string-match-p "Second text" kill-ring-text))
      (should (string-match-p "First text" html))
      (should (string-match-p "Second text" html)))))

