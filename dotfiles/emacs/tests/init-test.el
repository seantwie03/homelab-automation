(ert-deftest my/org-visible-fold-level-detects-the-current-outline-depth ()
  (save-window-excursion
    (with-temp-buffer
      (org-mode)
      (insert "* Parent\n** Child\n*** Grandchild\n")
      (set-window-buffer (selected-window) (current-buffer))
      (goto-char (point-min))
      (outline-hide-sublevels 2)
      (should (= (my--org-visible-fold-level) 2)))))

(ert-deftest my/org-hide-next-fold-level-decreases-the-visible-level ()
