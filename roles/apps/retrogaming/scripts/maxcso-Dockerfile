FROM ubuntu:latest AS builder

RUN apt-get update && apt-get install -y \
    build-essential \
    pkgconf \
    git \
    zlib1g-dev \
    liblz4-dev \
    libdeflate-dev \
    libuv1-dev

RUN git clone https://github.com/unknownbrackets/maxcso /build
WORKDIR /build
RUN make

FROM ubuntu:latest
RUN apt-get update && apt-get install -y \
    liblz4-1 \
    libdeflate0 \
    libuv1t64 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/maxcso /usr/local/bin/maxcso

ENTRYPOINT ["maxcso"]
