#!/bin/bash
if [ "$(id -u)" -ne 0 ]; then
    echo "this script must be run as root" >&2
    exit 1
fi

body=$(cat)

count=$(echo "$body" | awk '
    /^Upgrading:/  { in_section=1; next }
    /^[^ ]/        { in_section=0 }
    in_section && /^ [^ ]/ { count++ }
    END { print count+0 }
')

if [ "$count" -eq 0 ]; then
    exit 0
fi

# notify-send must be run as the desktop user, not root. The D-Bus session bus
# socket is owned by the user and rejects connections from other UIDs — even root.
# We check the socket exists first so this script exits silently on headless systems
# (e.g. servers) where no user session is running.
dbus_socket="/run/user/{{ uid }}/bus"
if [ ! -S "$dbus_socket" ]; then
    exit 0
fi

export DBUS_SESSION_BUS_ADDRESS="unix:path=${dbus_socket}"

runuser -u {{ user }} -- \
    notify-send \
        --urgency=normal \
        --app-name="dnf-automatic" \
        "System Updated" \
        "${count} packages upgraded"

if ! dnf needs-restarting &>/dev/null; then
    runuser -u {{ user }} -- \
        notify-send \
            --urgency=critical \
            --app-name="dnf-automatic" \
            "Reboot Required" \
            "A reboot is required to apply package updates."
fi
